# RetentionAI — Environment Configuration Template
# =====================================================
# Copy this file to .env and fill in your keys.
# NEVER commit .env to version control.

# ── OpenAI (LangChain outreach generation) ─────────────────────────────────
OPENAI_API_KEY=sk-...your-key-here...

# ── App config ─────────────────────────────────────────────────────────────
APP_ENV=development          # development | production
PORT=8000
BANK_NAME=HD Bank            # Displayed in outreach messages

# ── CORS (comma-separated allowed origins) ─────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:5500

# ── Model paths (override defaults if needed) ──────────────────────────────
# MODEL_PATH=backend/models/xgb_churn.pkl

# ── Optional: Redis cache ──────────────────────────────────────────────────
# REDIS_URL=redis://localhost:6379/0
